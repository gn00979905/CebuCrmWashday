{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ▼▼▼ 從這裡開始加入 YARP 的設定 ▼▼▼
  "ReverseProxy": {
    "Clusters": {
      "washdayCluster": {
        "Destinations": {
          "washday1": {
            "Address": "http://127.0.0.1:5001"
          }
        }
      }
    },
    "Routes": {
      "washdayRoute": {
        "ClusterId": "washdayCluster",
        "Match": {
          "Path": "{**catch-all}"
        },
        //加上這段 Transforms，把真正的網址告訴洗衣店
        "Transforms": [
          {
            "X-Forwarded": "Set",
            "For": "Append",
            "Proto": "Append",
            "Host": "Append"
          }
        ]
      }
    }
  }
}