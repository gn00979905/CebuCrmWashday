<!DOCTYPE html>
<style>

    /* 讓 nav-item 有平滑的過渡效果 */
    .navbar-nav .nav-item {
        transition: all 0.3s ease;
        margin: 0 2px; /* 每個按鈕之間留一點點空隙 */
        border-radius: 5px; /* 圓角效果 */
    }

        /* 滑鼠懸停時的背景與文字變化 */
        .navbar-nav .nav-item:hover {
            background-color: #f0f2f5; /* 淺灰色背景 */
        }

            /* 滑鼠懸停時，裡面的連結文字變色 */
            .navbar-nav .nav-item:hover .nav-link {
                color: #0d6efd !important; /* Bootstrap 的 Primary 藍色 */
            }
</style>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WASHDAY </title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://unpkg.com/tabulator-tables@5.6.1/dist/css/tabulator.min.css" rel="stylesheet">
    <link href="https://unpkg.com/tabulator-tables@5.6.1/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">

    <style>
        /* Navbar Brand (WASHDAY 文字) Hover 效果 */
        .navbar-brand {
            transition: all 0.3s ease;
        }

            .navbar-brand:hover {
                color: #0d6efd !important;
                transform: scale(1.05); /* 稍微放大 */
                cursor: pointer;
            }

        /* 順便附上您剛剛問的 li (選單項目) Hover 效果 */
        .navbar-nav .nav-item {
            transition: all 0.3s ease;
            margin: 0 2px;
            border-radius: 5px;
        }

            .navbar-nav .nav-item:hover {
                background-color: #f0f2f5;
            }

                .navbar-nav .nav-item:hover .nav-link {
                    color: #0d6efd !important;
                }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid main-content-wrapper">
                <a class="navbar-brand" asp-area="" asp-page="/Index">WASHDAY</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                      @*   <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Index">Dashboard</a>
                        </li> *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Reports"><i class="bi bi-clipboard-data"> Reports</i></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/MonthlySummary"><i class="bi bi-currency-dollar"> Summary</i></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Customers"><i class="bi bi-people-fill"> Customers</i></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Orders/Orders"><i class="bi bi-list-task"> Walk-in</i></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/LedgerGrid"><i class="bi bi-pc-display-horizontal"> Ledger (Laptop)</i></a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/DailyLedgers/Ledgers"><i class="bi bi-phone-fill"> Ledger (Mobile)</i></a>
                        </li>
                        @*<li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Import">Import</a>
                        </li> *@
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item ms-auto">
                                <a class="nav-link text-dark" asp-area="" asp-page="/Logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container-fluid main-content-wrapper">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container-fluid">
            &copy; 2025 - WASHDAY - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div id="appToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <strong class="me-auto">Notification</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" id="toast-body-content">
                <!-- Toast message will be injected here -->
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- ===== ↓↓↓ 新增 Toast 輔助函式 ↓↓↓ ===== -->
    <script>
        // 全局 Toast 輔助函式
        function showToast(message, type = 'success', duration = 10000) {
            const toastEl = document.getElementById('appToast');
            const toastBody = document.getElementById('toast-body-content');

            toastBody.innerText = message;

            // 移除舊的顏色 class
            toastEl.classList.remove('bg-success', 'bg-danger', 'bg-warning', 'text-white', 'text-dark');

            // 根據 type 加上新的顏色 class
            if (type === 'danger') {
                toastEl.classList.add('bg-danger', 'text-white');
            } else if (type === 'warning') {
                toastEl.classList.add('bg-warning', 'text-dark');
            } else {
                // 預設為 success
                toastEl.classList.add('bg-success', 'text-white');
            }
            // --- 關鍵修改點 ---
            // 1. 建立設定物件，設定 delay 為傳入的 duration
            const toastOptions = {
                delay: duration,
                // 預設 hide (自動關閉) 設為 true
                autohide: true
            };
            const toast = new bootstrap.Toast(toastEl, toastOptions);
            toast.show();
        }
    </script>
    <!-- ===== ↑↑↑ 新增輔助函式結束 ↑↑↑ ===== -->
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>