@page
@model WASHDAY_202508.Pages.DailyLedgers.DailyLedgerIndexModel

@{
    ViewData["Title"] = "Daily Ledger";
}

<style>
    /* 讓 nav-item 有平滑的過渡效果 */
    .nav-item {
        transition: all 0.3s ease;
        margin: 0 2px; /* 每個按鈕之間留一點點空隙 */
        border-radius: 5px; /* 圓角效果 */
    }

        /* 滑鼠懸停時的背景與文字變化 */
        .nav-item:hover {
            background-color: #f0f2f5; /* 淺灰色背景 */
        }

            /* 滑鼠懸停時，裡面的連結文字變色 */
            .nav-item:hover .nav-link {
                color: #0d6efd !important; /* Bootstrap 的 Primary 藍色 */
            }
    /* --- 通用設定 --- */
    .card-modern {
        border: none;
        box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
    }

    /* --- 導覽列優化 (RWD 核心) --- */
    /* 讓 Nav Pills 在手機上可以左右滑動，不會換行擠成一團 */
    .mobile-scroll-nav {
        display: flex;
        flex-wrap: nowrap; /* 禁止換行 */
        overflow-x: auto; /* 允許水平捲動 */
        padding-bottom: 10px; /* 預留捲軸空間 */
        -webkit-overflow-scrolling: touch; /* 讓 iOS 捲動更順暢 */
        gap: 8px; /* 按鈕間距 */
        scrollbar-width: none; /* Firefox 隱藏捲軸 */
    }

        /* 隱藏 Chrome/Safari 的捲軸但保留功能 */
        .mobile-scroll-nav::-webkit-scrollbar {
            display: none;
        }

        .mobile-scroll-nav .nav-item {
            flex: 0 0 auto; /* 防止按鈕被壓縮 */
        }

    .nav-pills a {
        padding: 6px 15px;
        border: 1px solid #dee2e6;
        border-radius: 20px; /* 變成圓膠囊狀 */
        color: #5a5c69;
        white-space: nowrap; /* 防止文字斷行 */
        transition: all 0.2s;
    }

        .nav-pills a.active {
            background-color: #4e73df;
            color: white;
            border-color: #4e73df;
            box-shadow: 0 2px 4px rgba(78, 115, 223, 0.25);
        }

    /* --- 手機版卡片樣式 (Mobile Only) --- */
    .ledger-card {
        background: white;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 15px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        border: 1px solid #f0f0f0;
    }

    .ledger-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px dashed #e3e6f0;
        padding-bottom: 10px;
        margin-bottom: 10px;
    }

    .ledger-card-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 6px;
        font-size: 0.9rem;
        color: #555;
    }

    .ledger-card-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        margin-top: 12px;
        padding-top: 10px;
        border-top: 1px solid #f8f9fc;
    }

    /* --- 表格樣式 (保留原本電腦版風格) --- */
    .excel-table th {
        background-color: #FFD966;
        text-align: center;
        vertical-align: middle;
        font-size: 0.9rem;
    }

    /* 數字靠右對齊 */
    .text-end {
        text-align: right;
    }

</style>

<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<div class="container-fluid px-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h4 fw-bold text-dark mb-1">Daily Ledgers</h1>
            <p class="text-muted small mb-0">easy to use in the mobile devices or small screens like tablet or phone</p>
            <p class="text-muted small mb-0">Press the blue button: "<i class="bi bi-plus-circle me-1"></i>"(plus sign) to Add New Row, Press "<i class="bi bi-pencil"></i>" for Edit...etc.</p>
        </div>
        <a asp-page="/Create" class="btn btn-primary rounded-pill shadow-sm btn-sm-mobile">
            <i class="bi bi-plus-circle me-1"></i> <span class="d-none d-sm-inline">New Row Entry</span>
        </a>
    </div>

    <div class="mb-4">
        <div class="mobile-scroll-nav nav-pills mb-2">
            <div class="nav-item">
                <a class="@(Model.CurrentYear == null ? "active" : "")" asp-page="./Ledgers" asp-route-all=1>All</a>
            </div>
            @foreach (var year in Model.AvailableYears)
            {
                <div class="nav-item">
                    <a class="@(Model.CurrentYear == year ? "active" : "")" asp-page="./Ledgers" asp-route-year="@year">@year</a>
                </div>
            }
        </div>

        @if (Model.CurrentYear.HasValue)
        {
            <div class="mobile-scroll-nav nav-pills">
                @for (int i = 1; i <= 12; i++)
                {
                    var monthAbbr = new DateTime(Model.CurrentYear.Value, i, 1).ToString("MMM").ToUpper();
                    <div class="nav-item">
                        <a class="@(Model.CurrentMonth == i ? "active" : "")" asp-page="./Ledgers" asp-route-year="@Model.CurrentYear" asp-route-month="@i">@monthAbbr</a>
                    </div>
                }
            </div>
        }
    </div>

    <div class="d-flex justify-content-end mb-3">
        <a class="btn btn-sm btn-outline-success" asp-page-handler="Export"
           asp-route-CurrentYear="@Model.CurrentYear"
           asp-route-CurrentMonth="@Model.CurrentMonth">
            <i class="bi bi-file-earmark-excel"></i> <span class="d-none d-sm-inline">Export Excel</span>
        </a>
    </div>

    <div class="d-none d-md-block card card-modern bg-white">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 excel-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th class="text-end">Walk-in</th>
                            <th class="text-end">San Marino</th>
                            <th class="text-end">Sunvida</th>
                            <th class="text-end">Cebu Rooms</th>
                            <th class="text-end">Sugbu</th>
                            <th class="text-end bg-warning bg-opacity-10">Total Sales</th>
                            <th class="text-end">Expenses</th>
                            <th class="text-end bg-success bg-opacity-10">Net Sales</th>
                            <th class="text-center" style="width: 150px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.DailyLedger)
                        {
                            <tr>
                                <td class="fw-bold">@item.EntryDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-end text-muted">₱ @item.SalesWalkIn.ToString("N0")</td>
                                <td class="text-end text-muted">₱ @item.SanMarino.ToString("N0")</td>

                                <td class="text-end text-muted">₱ @item.Sunvida.ToString("N0")</td>
                                <td class="text-end text-muted">₱ @item.CebuRooms.ToString("N0")</td>
                                <td class="text-end text-muted">₱ @item.SugbuMercado.ToString("N0")</td>
                                <td class="text-end fw-bold text-primary bg-warning bg-opacity-10">₱ @item.TotalSales.ToString("N2")</td>
                                <td class="text-end text-danger">₱ @item.Expenses.ToString("N2")</td>
                                <td class="text-end fw-bold text-success bg-success bg-opacity-10">₱ @item.NetSales.ToString("N2")</td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-page="/Edit" asp-route-id="@item.Id" class="btn btn-outline-primary"><i class="bi bi-pencil"></i></a>
                                        <a asp-page="/Details" asp-route-id="@item.Id" class="btn btn-outline-secondary"><i class="bi bi-eye"></i></a>
                                        <a asp-page="/Delete" asp-route-id="@item.Id" class="btn btn-outline-danger"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="d-md-none">
        @foreach (var item in Model.DailyLedger)
        {
            <div class="ledger-card">
                <div class="ledger-card-header">
                    <span class="fw-bold text-dark" style="font-size: 1.1rem;">
                        @item.EntryDate.ToString("MM/dd") <small class="text-muted">@item.EntryDate.ToString("yyyy")</small>
                    </span>
                    <span class="badge bg-success bg-opacity-10 text-success px-2 py-1 fs-6">
                        ₱ @item.NetSales.ToString("N2")
                    </span>
                </div>

                <div class="card-content">
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <div class="small text-muted">Walk-in</div>
                            <div class="fw-bold">₱ @item.SalesWalkIn.ToString("N0")</div>
                        </div>
                        <div class="col-6">
                            <div class="small text-muted">SanMarino</div>
                            <div class="fw-bold">₱ @item.SanMarino.ToString("N0")</div>
                        </div>
                        <div class="col-6">
                            <div class="small text-muted">Sunvida</div>
                            <div class="fw-bold">₱ @item.Sunvida.ToString("N0")</div>
                        </div>
                        <div class="col-6">
                            <div class="small text-muted">Cebu Rooms</div>
                            <div class="fw-bold">₱ @item.CebuRooms.ToString("N0")</div>
                        </div>
                        <div class="col-6">
                            <div class="small text-muted">Sugbu</div>
                            <div class="fw-bold">₱ @item.SugbuMercado.ToString("N0")</div>
                        </div>
                    </div>

                    <div style="border-top: 1px solid #eee; margin: 8px 0;"></div>

                    <div class="ledger-card-row">
                        <span>Total Sales</span>
                        <span class="fw-bold text-primary">₱ @item.TotalSales.ToString("N2")</span>
                    </div>
                    <div class="ledger-card-row">
                        <span>Expenses</span>
                        <span class="text-danger">₱ @item.Expenses.ToString("N2")</span>
                    </div>
                </div>

                <div class="ledger-card-actions">
                    <a asp-page="/Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary w-100">
                        <i class="bi bi-pencil"></i> Edit
                    </a>
                    <a asp-page="/Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary w-100">
                        <i class="bi bi-eye"></i> View
                    </a>
                    <a asp-page="/Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        }
    </div>

</div>