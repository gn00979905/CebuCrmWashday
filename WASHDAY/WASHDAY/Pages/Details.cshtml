@page
@model WASHDAY_202508.Pages.DetailsModel

@{
    ViewData["Title"] = "Details";
}
<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 fw-bold">Ledger Details</h1>
        <div>
            <a asp-page="./Edit" asp-route-id="@Model.DailyLedger.Id" class="btn btn-outline-primary me-2">
                <i class="bi bi-pencil"></i> Edit
            </a>
            <a asp-page="/DailyLedgers/Ledgers" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>
    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card card-modern h-100">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 text-center">@Model.DailyLedger.EntryDate.ToString("yyyy-MM-dd")</h5>
                    <div class="text-center opacity-75 small">Entry Date</div>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between py-3">
                            <span class="text-muted">Walk-in Sales</span>
                            <span class="fw-bold">₱ @Model.DailyLedger.SalesWalkIn.ToString("N2")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between py-3">
                            <span class="text-muted">Cebu Rooms</span>
                            <span class="fw-bold">₱ @Model.DailyLedger.CebuRooms.ToString("N2")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between py-3">
                            <span class="text-muted">Descriptions</span>
                            <span class="fw-bold">@Model.DailyLedger.Description</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between py-3 bg-light">
                            <span class="fw-bold text-primary">Total Sales</span>
                            <span class="fw-bold text-primary fs-5">₱ @Model.DailyLedger.TotalSales.ToString("N2")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between py-3">
                            <span class="text-danger">Total Expenses</span>
                            <span class="fw-bold text-danger">₱ @Model.DailyLedger.Expenses.ToString("N2")</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between py-3 bg-success bg-opacity-10">
                            <span class="fw-bold text-success">Net Income</span>
                            <span class="fw-bold text-success fs-4">₱ @Model.DailyLedger.NetSales.ToString("N2")</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="col-md-7 mb-4">
            <div class="card card-modern h-100">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-4">Expense Breakdown</h5>

                    @if (Model.DailyLedger.ExpenseItems != null && Model.DailyLedger.ExpenseItems.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Category</th>
                                        <th>Description</th>
                                        <th class="text-end">Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var exp in Model.DailyLedger.ExpenseItems)
                                    {
                                        <tr>
                                            <td><span class="badge bg-secondary bg-opacity-10 text-dark">@exp.Category</span></td>
                                            <td class="text-muted small">@exp.Description</td>
                                            <td class="text-end fw-bold">₱ @exp.Amount.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-wallet2 display-4 mb-3 d-block"></i>
                            No expenses recorded for this date.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

